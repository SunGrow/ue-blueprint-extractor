{
  "name": "blueprint-extractor-mcp",
  "version": "2.0.0",
  "description": "MCP server for the Unreal Engine BlueprintExtractor plugin over Remote Control",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "blueprint-extractor-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "unreal-engine",
    "ue5",
    "blueprint",
    "remote-control"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SunGrow/ue-blueprint-extractor.git",
    "directory": "MCP"
  },
  "bugs": {
    "url": "https://github.com/SunGrow/ue-blueprint-extractor/issues"
  },
  "homepage": "https://github.com/SunGrow/ue-blueprint-extractor#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "npm run test:unit && npm run test:stdio",
    "test:unit": "vitest run tests/ue-client.test.ts tests/project-controller.test.ts tests/server-contract.test.ts",
    "test:stdio": "npm run build && vitest run tests/stdio.integration.test.ts",
    "test:live": "npm run build && vitest run tests/live.e2e.test.ts",
    "test:pack-smoke": "node tests/pack-smoke.mjs",
    "test:publish-gate": "node tests/publish-gate.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.1"
  }
}
